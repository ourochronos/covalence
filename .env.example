# =============================================================================
# Covalence — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in the values relevant to your setup.
# The .env file is loaded automatically by docker-compose (optional/ignored
# if missing) and by the engine via `dotenvy` when running locally.
#
#   cp .env.example .env
#   # edit .env ...
#   docker compose up -d          # full stack
#   # -- or --
#   cd engine && cargo run        # engine only (postgres must be running)
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Full PostgreSQL connection string.
# When running inside docker compose the hostname is `postgres` (the service
# name).  When running the engine directly on your host use `localhost:5434`
# (the port mapped by docker-compose for the standalone postgres service).
#
# compose default (set automatically by docker-compose.yml — no need to change):
DATABASE_URL=postgres://covalence:covalence@postgres:5432/covalence
#
# local development default:
# DATABASE_URL=postgres://covalence:covalence@localhost:5434/covalence

# -----------------------------------------------------------------------------
# Engine HTTP server
# -----------------------------------------------------------------------------

# Interface and port the engine HTTP server binds to.
# Default: 0.0.0.0:8430
# BIND_ADDR=0.0.0.0:8430

# Rust/tower tracing log filter.
# Default: covalence_engine=debug,tower_http=debug
# RUST_LOG=covalence_engine=info,tower_http=info

# -----------------------------------------------------------------------------
# LLM / Embeddings  (optional — engine works without these but compilation
# and vector search will be degraded/disabled)
# -----------------------------------------------------------------------------

# OpenAI API key.  Used for:
#   • text-embedding-3-small embeddings (pgvector HNSW search)
#   • GPT-based article compilation in the slow-path queue
# OPENAI_API_KEY=sk-...

# Override the OpenAI base URL to point at a compatible proxy or local model
# server (e.g. LM Studio, Ollama with openai compat, Azure OpenAI, etc.).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Override the embedding model name (default: text-embedding-3-small).
# COVALENCE_EMBED_MODEL=text-embedding-3-small

# URL of an OpenAI-compatible inference proxy used by the OpenClaw plugin for
# chat completions and embeddings.  Not required by the engine itself.
# INFERENCE_URL=http://localhost:11434/v1

# -----------------------------------------------------------------------------
# Migration runner  (docker/run-migrations.sh)
# These are set automatically by docker-compose.yml when using the engine
# service — you only need to set them if you run run-migrations.sh manually.
# -----------------------------------------------------------------------------

# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=covalence
# DB_USER=covalence
# DB_PASSWORD=covalence
# SQL_DIR=/app/sql
# ENGINE_BIN=/app/covalence-engine
# MAX_WAIT=60
