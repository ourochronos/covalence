DATABASE_URL=postgres://covalence:covalence@localhost:5435/covalence_dev
BIND_ADDR=0.0.0.0:8431
RUST_LOG=info

# Optional API key to protect endpoints
COVALENCE_API_KEY=

# Embedding provider (any OpenAI-compatible API)
# For Voyage AI:
#   OPENAI_API_KEY=pa-your-voyage-key
#   OPENAI_BASE_URL=https://api.voyageai.com/v1
#   COVALENCE_EMBED_MODEL=voyage-3-large
#   COVALENCE_EMBED_DIM=1024
# For OpenAI:
#   OPENAI_API_KEY=sk-your-openai-key
#   COVALENCE_EMBED_MODEL=text-embedding-3-large
#   COVALENCE_EMBED_DIM=2048
OPENAI_API_KEY=
OPENAI_BASE_URL=
COVALENCE_EMBED_MODEL=
COVALENCE_EMBED_DIM=1024

# LLM for entity extraction (requires chat completions API)
# Leave COVALENCE_CHAT_MODEL empty to disable extraction
COVALENCE_CHAT_MODEL=
