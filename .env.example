# Covalence loads configuration from (highest precedence last):
#   1. Hardcoded defaults
#   2. covalence.conf (YAML, optional)
#   3. covalence.conf.d/*.conf (YAML overrides, optional)
#   4. Environment variables (this file, loaded via dotenvy)
#
# Env vars use COVALENCE_ prefix with __ for nesting:
#   COVALENCE_EMBEDDING__PROVIDER=voyage
#
# Legacy flat env var names are also supported for backward compat:
#   DATABASE_URL, BIND_ADDR, OPENAI_API_KEY, VOYAGE_API_KEY,
#   COVALENCE_EMBED_PROVIDER, COVALENCE_CHAT_MODEL, etc.

DATABASE_URL=postgres://covalence:covalence@localhost:5435/covalence_dev
BIND_ADDR=0.0.0.0:8431
RUST_LOG=info

# Optional API key to protect endpoints
COVALENCE_API_KEY=

# ── Embedding provider ──────────────────────────────────────────
# Voyage AI (recommended):
#   VOYAGE_API_KEY=pa-your-voyage-key
#   COVALENCE_EMBED_PROVIDER=voyage
#   COVALENCE_EMBED_MODEL=voyage-3-large
#
# OpenAI:
#   OPENAI_API_KEY=sk-your-openai-key
#   COVALENCE_EMBED_MODEL=text-embedding-3-large

OPENAI_API_KEY=
OPENAI_BASE_URL=
VOYAGE_API_KEY=
COVALENCE_EMBED_PROVIDER=voyage
COVALENCE_EMBED_MODEL=voyage-3-large

# Per-table embedding dimensions (matryoshka truncation).
# Max dimension is generated, then truncated + renormalized per table.
# COVALENCE_EMBED_DIM_SOURCE=2048
# COVALENCE_EMBED_DIM_CHUNK=1024
# COVALENCE_EMBED_DIM_NODE=256
# COVALENCE_EMBED_DIM_ARTICLE=1024
# COVALENCE_EMBED_DIM_STATEMENT=1024
# COVALENCE_EMBED_DIM_SECTION=1024

# ── Chat / LLM backend ─────────────────────────────────────────
# Backend type: "cli" (shells out to claude/gemini/copilot) or "http"
COVALENCE_CHAT_BACKEND=cli
COVALENCE_CHAT_CLI_COMMAND=claude
COVALENCE_CHAT_MODEL=haiku

# Statement pipeline model (defaults to COVALENCE_CHAT_MODEL)
# COVALENCE_STATEMENT_MODEL=haiku

# Enable/disable statement-first extraction pipeline
# COVALENCE_STATEMENT_ENABLED=true

# ── Graph engine ────────────────────────────────────────────────
# "petgraph" (in-memory sidecar) or "age" (Apache AGE in PostgreSQL)
COVALENCE_GRAPH_ENGINE=petgraph

# ── Entity extraction ───────────────────────────────────────────
# Extractor type: "llm" (default), "sidecar", "gliner2", "two_pass"
# COVALENCE_ENTITY_EXTRACTOR=llm
# COVALENCE_EXTRACT_URL=http://localhost:8433

# ── Sidecars ────────────────────────────────────────────────────
# Fastcoref coreference resolution
# COVALENCE_COREF_URL=http://localhost:8433

# PDF → Markdown conversion
# COVALENCE_PDF_URL=http://localhost:8434

# ReaderLM HTML → Markdown
# COVALENCE_READERLM_URL=http://localhost:8432

# ── Queue / pipeline ───────────────────────────────────────────
# COVALENCE_QUEUE_POLL_INTERVAL=2
# COVALENCE_QUEUE_EXTRACT_CONCURRENCY=24
# COVALENCE_QUEUE_SUMMARIZE_CONCURRENCY=10
# COVALENCE_QUEUE_COMPOSE_CONCURRENCY=5
# COVALENCE_QUEUE_EMBED_CONCURRENCY=4

# ── Ask endpoint ────────────────────────────────────────────────
# Model for grounded Q&A synthesis (default: sonnet)
# COVALENCE_ASK_MODEL=sonnet
